{
  "providers": [
    {
      "id": "glm",
      "name": "GLM 智谱",
      "type": "http",
      "parserTemplate": "quota_windows",
      "enabled": true,
      "endpoint": "https://open.bigmodel.cn/api/monitor/usage/quota/limit",
      "authHeader": "Authorization",
      "authPrefix": "Bearer ",
      "credentialKey": "apiKey",
      "refreshIntervalSec": 120,
      "supportsQuota": true,
      "supportsApiUsage": false,
      "fields": {
        "limitsArray": "data.limits"
      }
    },
    {
      "id": "deepseek",
      "name": "DeepSeek",
      "type": "http",
      "parserTemplate": "balance_json",
      "enabled": true,
      "endpoint": "https://api.deepseek.com/user/balance",
      "authHeader": "Authorization",
      "authPrefix": "Bearer ",
      "credentialKey": "apiKey",
      "refreshIntervalSec": 300,
      "supportsQuota": false,
      "supportsApiUsage": true
    },
    {
      "id": "kimi",
      "name": "Kimi 月之暗面",
      "type": "http",
      "parserTemplate": "balance_json",
      "enabled": true,
      "endpoint": "https://api.moonshot.cn/v1/users/me/balance",
      "authHeader": "Authorization",
      "authPrefix": "Bearer ",
      "credentialKey": "apiKey",
      "refreshIntervalSec": 300,
      "supportsQuota": false,
      "supportsApiUsage": true
    },
    {
      "id": "openai",
      "name": "OpenAI",
      "type": "http",
      "parserTemplate": "openai_costs",
      "enabled": true,
      "endpoint": "https://api.openai.com/v1/organization/costs?start_time={month_start}",
      "authHeader": "Authorization",
      "authPrefix": "Bearer ",
      "credentialKey": "apiKey",
      "refreshIntervalSec": 600,
      "supportsQuota": false,
      "supportsApiUsage": true
    },
    {
      "id": "demo",
      "name": "Demo 演示",
      "type": "demo",
      "enabled": true,
      "refreshIntervalSec": 60,
      "supportsQuota": true,
      "supportsApiUsage": true
    }
  ]
}
